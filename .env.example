# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL Database Configuration
DB_ENGINE=django.db.backends.mysql
DB_NAME=bursary_db
DB_USER=bursary_app
DB_PASSWORD=your_app_mysql_password
DB_HOST=localhost
DB_PORT=3306

# Email Configuration (Required for Password Reset)
# For development, use console backend to print emails in terminal
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production, use SMTP backend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# Gmail: Use your email and app-specific password (not your regular password)
# Create app password: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
DEFAULT_FROM_EMAIL=noreply@bursary.com
